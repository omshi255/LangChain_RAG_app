{
  "info": {
    "name": "RAG System API",
    "_postman_id": "rag-system-collection-v1",
    "description": "Complete RAG System — Upload PDFs and Query them using Groq + Pinecone.\n\n## Setup\n1. Set `base_url` variable to your server URL\n2. Run `POST /upload` first → copy `document_id` from response\n3. Paste `document_id` into collection variable\n4. Run `POST /query` to ask questions\n\nSwagger UI: {{base_url}}/docs",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "type": "string",
      "description": "Base URL of your FastAPI server"
    },
    {
      "key": "document_id",
      "value": "",
      "type": "string",
      "description": "Paste document_id here after uploading a PDF"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/",
              "host": ["{{base_url}}"],
              "path": [""]
            },
            "description": "Check if the server is running"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Server is running', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Status is ok', function() {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.status).to.eql('ok');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Detailed Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
              "host": ["{{base_url}}"],
              "path": ["health"]
            },
            "description": "Get detailed system info — models, Pinecone index, chunk config"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Health returns 200', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Has llm_model field', function() {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('llm_model');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Document Upload",
      "item": [
        {
          "name": "Upload PDF",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "",
                  "description": "Select your PDF file here"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/upload/",
              "host": ["{{base_url}}"],
              "path": ["upload", ""]
            },
            "description": "Upload a PDF to extract, chunk, embed and store in Pinecone.\n\n**Steps:**\n1. Click Body tab\n2. Select the file field\n3. Choose your PDF\n4. Send\n5. Copy `document_id` from response → paste into collection variables"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Upload successful', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has document_id', function() {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('document_id');",
                  "    pm.expect(json.document_id).to.be.a('string');",
                  "    pm.expect(json.document_id.length).to.be.greaterThan(0);",
                  "});",
                  "",
                  "pm.test('Chunks were stored', function() {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.chunks_stored).to.be.greaterThan(0);",
                  "});",
                  "",
                  "// Auto-save document_id to collection variable",
                  "const json = pm.response.json();",
                  "if (json.document_id) {",
                  "    pm.collectionVariables.set('document_id', json.document_id);",
                  "    console.log('document_id saved:', json.document_id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Upload PDF — Empty File (Error Test)",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "",
                  "description": "Attach an empty file to test error handling"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/upload/",
              "host": ["{{base_url}}"],
              "path": ["upload", ""]
            },
            "description": "Test error handling when an empty file is uploaded. Should return 422."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Empty file returns 422', function() {",
                  "    pm.response.to.have.status(422);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "RAG Query",
      "item": [
        {
          "name": "Query — With Document ID",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"question\": \"What is this document about?\",\n  \"document_id\": \"{{document_id}}\",\n  \"top_k\": 5\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/query/",
              "host": ["{{base_url}}"],
              "path": ["query", ""]
            },
            "description": "Ask a question filtered to a specific document.\n\n**Requires:** `document_id` variable to be set (auto-set after Upload PDF request)."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Query returns 200', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has answer', function() {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('answer');",
                  "    pm.expect(json.answer.length).to.be.greaterThan(0);",
                  "});",
                  "",
                  "pm.test('Response has sources', function() {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('sources');",
                  "    pm.expect(json.sources).to.be.an('array');",
                  "});",
                  "",
                  "pm.test('Response echoes question', function() {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('question');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Query — All Documents (No Filter)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"question\": \"Summarize the key points\",\n  \"top_k\": 5\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/query/",
              "host": ["{{base_url}}"],
              "path": ["query", ""]
            },
            "description": "Query across ALL uploaded documents (no document_id filter)."
          },
          "response": []
        },
        {
          "name": "Query — Custom Top-K",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"question\": \"What are the main conclusions?\",\n  \"document_id\": \"{{document_id}}\",\n  \"top_k\": 10\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/query/",
              "host": ["{{base_url}}"],
              "path": ["query", ""]
            },
            "description": "Query with top_k=10 to retrieve more context chunks."
          },
          "response": []
        },
        {
          "name": "Query — Empty Question (Error Test)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"question\": \"\",\n  \"document_id\": \"{{document_id}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/query/",
              "host": ["{{base_url}}"],
              "path": ["query", ""]
            },
            "description": "Test error handling for empty question. Should return 422."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Empty question returns 422', function() {",
                  "    pm.response.to.have.status(422);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Query — No Matching Context (Edge Case)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"question\": \"xyzzy frobnicator quantum entanglement of purple elephants\",\n  \"document_id\": \"{{document_id}}\",\n  \"top_k\": 5\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/query/",
              "host": ["{{base_url}}"],
              "path": ["query", ""]
            },
            "description": "Tests graceful handling when no relevant context is found in the document."
          },
          "response": []
        }
      ]
    }
  ]
}
