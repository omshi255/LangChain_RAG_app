    {
      "name": "RAG Query",
      "item": [
        {
          "name": "Query — With Document ID",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"question\": \"What is this document about?\",\n  \"document_id\": \"{{document_id}}\",\n  \"top_k\": 5\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/query/",
              "host": ["{{base_url}}"],
              "path": ["query", ""]
            },
            "description": "Ask a question filtered to a specific document.\n\nRequires: document_id variable (auto-set after any upload request)."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Query returns 200', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response has answer', function() {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('answer');",
                  "    pm.expect(json.answer.length).to.be.greaterThan(0);",
                  "});",
                  "pm.test('Response has sources', function() {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('sources');",
                  "    pm.expect(json.sources).to.be.an('array');",
                  "});",
                  "pm.test('Response echoes question', function() {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('question');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
