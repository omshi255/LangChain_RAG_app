      "item": [
        {
          "name": "Upload PDF",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "",
                  "description": "Select your PDF file here"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/upload/",
              "host": ["{{base_url}}"],
              "path": ["upload", ""]
            },
            "description": "Upload a PDF → extract text → chunk → embed → store in Pinecone.\n\n1. Click Body tab\n2. Select file field → choose your PDF\n3. Send\n4. document_id is auto-saved to collection variables"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Upload successful', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response has document_id', function() {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('document_id');",
                  "    pm.expect(json.document_id).to.be.a('string');",
                  "    pm.expect(json.document_id.length).to.be.greaterThan(0);",
                  "});",
                  "pm.test('Chunks were stored', function() {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.chunks_stored).to.be.greaterThan(0);",
                  "});",
                  "const json = pm.response.json();",
                  "if (json.document_id) {",
                  "    pm.collectionVariables.set('document_id', json.document_id);",
                  "    console.log('document_id saved:', json.document_id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
