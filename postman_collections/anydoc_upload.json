{
  "info": {
    "name": "RAG System API",
    "_postman_id": "rag-system-collection-v1",
    "description": "Complete RAG System — Upload any file (PDF, Word, Excel, CSV, PPT, Code, Images) and Query using Groq + Pinecone.\n\n## Setup\n1. Set `base_url` variable to your server URL\n2. Run any Upload request → `document_id` is auto-saved\n3. Run `POST /query` to ask questions\n\nSwagger UI: {{base_url}}/docs",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "type": "string",
      "description": "Base URL of your FastAPI server"
    },
    {
      "key": "document_id",
      "value": "",
      "type": "string",
      "description": "Auto-saved after any upload request"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/",
              "host": ["{{base_url}}"],
              "path": [""]
            },
            "description": "Check if the server is running"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Server is running', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Status is ok', function() {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.status).to.eql('ok');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Detailed Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
