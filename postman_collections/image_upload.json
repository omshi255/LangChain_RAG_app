{
  "name": "Upload Image",
  "request": {
    "method": "POST",
    "header": [],
    "body": {
      "mode": "formdata",
      "formdata": [
        {
          "key": "file",
          "type": "file",
          "src": "",
          "description": "Select your image (png, jpg, jpeg)"
        }
      ]
    },
    "url": {
      "raw": "{{base_url}}/api/upload-image",
      "host": ["{{base_url}}"],
      "path": ["api", "upload-image"]
    },
    "description": "Upload an image → OCR → embeddings → Pinecone storage.\n\nSteps:\n1. Go to Body tab\n2. Select file\n3. Choose image\n4. Send\n5. Copy document_id"
  },
  "response": [],
  "event": [
    {
      "listen": "test",
      "script": {
        "exec": [
          "pm.test('Image upload successful', function () {",
          "    pm.response.to.have.status(200);",
          "});",
          "",
          "pm.test('Response has document_id', function () {",
          "    const json = pm.response.json();",
          "    pm.expect(json).to.have.property('document_id');",
          "});",
          "",
          "// Save document_id",
          "const json = pm.response.json();",
          "if (json.document_id) {",
          "    pm.collectionVariables.set('document_id', json.document_id);",
          "}"
        ],
        "type": "text/javascript"
      }
    }
  ]
}